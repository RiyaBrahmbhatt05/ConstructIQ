@model ConstructionSimulator.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<section class="auth-shell">
    <div class="auth-container">
        <div class="auth-hero">
            <p class="auth-breadcrumb"><a asp-controller="Landing" asp-action="Index">Home</a> / Account</p>
            <h1 class="auth-title">Create Account</h1>
        </div>

        <div class="auth-wrap">
            <aside class="auth-side">
                <h2>Join ConstructorIQ</h2>
                <p>Set up your account and bring your team into one modern construction workspace with shared intelligence.</p>
                <ul class="auth-side-list">
                    <li>Secure account access for project teams</li>
                    <li>Unified material, crew, and task visibility</li>
                    <li>Faster delivery through better planning</li>
                </ul>
            </aside>

            <div class="auth-panel">
                <div class="auth-panel-head">
                    <h3>Registration Form</h3>
                    <p>Create your account details to start managing projects.</p>
                </div>

                <div class="auth-body">
                <form method="post" asp-action="Register" class="auth-form-grid">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="auth-error">
                            <strong>Registration Error</strong>
                            <p class="mb-0">@ViewBag.ErrorMessage</p>
                        </div>
                    }

                    <div class="auth-group auth-group-full">
                        <label class="auth-label" asp-for="FullName">Full Name</label>
                        <input class="auth-input" type="text" asp-for="FullName" placeholder="John Doe" />
                        <span asp-validation-for="FullName"></span>
                    </div>

                    <div class="auth-group auth-group-full">
                        <label class="auth-label" asp-for="Email">Email Address</label>
                        <input class="auth-input" type="email" asp-for="Email" placeholder="you@example.com" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <div class="auth-group">
                        <label class="auth-label" asp-for="Password">Password</label>
                        <input class="auth-input" type="password" asp-for="Password" placeholder="Create a strong password" id="passwordInput" />
                        <span asp-validation-for="Password"></span>
                    </div>

                    <div class="auth-group">
                        <label class="auth-label" asp-for="ConfirmPassword">Confirm Password</label>
                        <input class="auth-input" type="password" asp-for="ConfirmPassword" placeholder="Confirm your password" />
                        <span asp-validation-for="ConfirmPassword"></span>
                    </div>

                    <button type="submit" class="auth-submit">Create My Account</button>

                    <div class="auth-footer">
                        <p class="mb-0">Already have an account? <a asp-action="Login" class="auth-link">Sign in here</a></p>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
