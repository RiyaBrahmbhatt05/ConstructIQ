@model ConstructionSimulator.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<section class="auth-shell">
    <div class="auth-container">
        <div class="auth-hero">
            <p class="auth-breadcrumb"><a asp-controller="Landing" asp-action="Index">Home</a> / Account</p>
            <h1 class="auth-title">Sign In</h1>
        </div>

        <div class="auth-wrap">
            <aside class="auth-side">
                <h2>Build Smarter, Start Here</h2>
                <p>Welcome back to ConstructorIQ. Monitor costs, resolve conflicts, and keep your projects moving with confidence.</p>
                <ul class="auth-side-list">
                    <li>Real-time schedule and crew visibility</li>
                    <li>Conflict alerts before issues escalate</li>
                    <li>Budget tracking aligned to active tasks</li>
                </ul>
            </aside>

            <div class="auth-panel">
                <div class="auth-panel-head">
                    <h3>Account Access</h3>
                    <p>Sign in with your registered company email and password.</p>
                </div>

                <div class="auth-body">
                <form method="post" asp-action="Login">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="auth-error">
                            <strong>Login Failed</strong>
                            <p class="mb-0">@ViewBag.ErrorMessage</p>
                        </div>
                    }

                    <div class="auth-group">
                        <label class="auth-label" asp-for="Email">Email Address</label>
                        <input class="auth-input" type="email" asp-for="Email" placeholder="you@example.com" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <div class="auth-group">
                        <label class="auth-label" asp-for="Password">Password</label>
                        <input class="auth-input" type="password" asp-for="Password" placeholder="Enter your password" />
                        <span asp-validation-for="Password"></span>
                    </div>

                    <div class="auth-row-end">
                        <a href="#" class="auth-link">Forgot password?</a>
                    </div>

                    <div class="auth-check-row">
                        <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe" />
                        <label class="auth-check-label" for="rememberMe">
                            Keep me signed in
                        </label>
                    </div>

                    <button type="submit" class="auth-submit">Sign In</button>

                    <div class="auth-footer">
                        <p class="mb-0">Don't have an account? <a asp-action="Register" class="auth-link">Create one now</a></p>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
