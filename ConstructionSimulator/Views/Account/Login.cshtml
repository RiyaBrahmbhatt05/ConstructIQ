@model ConstructionSimulator.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<div style="display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 200px); padding: 2rem 0;">
    <div style="width: 100%; max-width: 450px; background: white; border-radius: 1rem; box-shadow: 0 20px 60px rgba(0,0,0,0.08); overflow: hidden;">

        <div style="background: linear-gradient(135deg, rgb(107,70,210) 0%, rgb(124,81,229) 100%); padding: 3rem 2rem; text-align: center; color: white;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🔐</div>
            <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0; padding: 0; margin-bottom: 0.5rem;">Welcome Back</h1>
            <p style="font-size: 0.95rem; opacity: 0.95; margin: 0;">Sign in to your Construction Simulator account</p>
        </div>

        <div style="padding: 2.5rem 2rem;">
            <form method="post" asp-action="Login">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div style="background: linear-gradient(135deg, rgb(254,226,226) 0%, rgb(254,202,202) 100%); color: rgb(185,28,28); border-left: 4px solid rgb(220,38,38); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem;">
                        <strong style="display: block; margin-bottom: 0.5rem; font-size: 0.95rem;">Login Failed</strong>
                        <p style="margin: 0; font-size: 0.9rem;">@ViewBag.ErrorMessage</p>
                    </div>
                }

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.5rem; color: rgb(31,41,55); font-weight: 600; font-size: 0.95rem;" asp-for="Email">Email Address</label>
                    <input class="form-control" type="email" asp-for="Email" placeholder="you@example.com" style="width: 100%; padding: 0.75rem 1rem; border: 2px solid rgb(229,231,235); border-radius: 0.5rem; font-size: 1rem; transition: all 0.3s ease; background-color: rgb(249,250,251);" />
                    <span asp-validation-for="Email" style="color: rgb(239,68,68); font-size: 0.85rem; margin-top: 0.375rem;"></span>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.5rem; color: rgb(31,41,55); font-weight: 600; font-size: 0.95rem;" asp-for="Password">Password</label>
                    <input class="form-control" type="password" asp-for="Password" placeholder="Enter your password" style="width: 100%; padding: 0.75rem 1rem; border: 2px solid rgb(229,231,235); border-radius: 0.5rem; font-size: 1rem; transition: all 0.3s ease; background-color: rgb(249,250,251);" />
                    <span asp-validation-for="Password" style="color: rgb(239,68,68); font-size: 0.85rem; margin-top: 0.375rem;"></span>
                </div>

                <div style="text-align: right; margin-bottom: 1rem;">
                    <a href="#" style="color: rgb(107,70,210); text-decoration: none; font-size: 0.9rem; font-weight: 500;">Forgot password?</a>
                </div>

                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                    <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe" style="width: 1.25rem; height: 1.25rem; border: 2px solid rgb(229,231,235); border-radius: 0.375rem; cursor: pointer;" />
                    <label style="cursor: pointer; color: rgb(31,41,55); margin: 0; font-weight: 500;" for="rememberMe">
                        Keep me signed in
                    </label>
                </div>

                <button type="submit" style="width: 100%; padding: 0.875rem; background: linear-gradient(135deg, rgb(107,70,210) 0%, rgb(124,81,229) 100%); color: white; border: none; border-radius: 0.5rem; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; margin-bottom: 1rem;">Sign In</button>

                <div style="text-align: center; padding-top: 1rem; border-top: 1px solid rgb(229,231,235);">
                    <p style="margin: 0; color: rgb(107,114,128); font-size: 0.95rem;">Don't have an account? <a asp-action="Register" style="color: rgb(107,70,210); text-decoration: none; font-weight: 600;">Create one now</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
