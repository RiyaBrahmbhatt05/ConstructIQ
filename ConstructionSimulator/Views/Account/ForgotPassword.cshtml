@model ConstructionSimulator.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="auth-shell">
    <div class="auth-container">
        <div class="auth-hero">
            <p class="auth-breadcrumb"><a asp-controller="Landing" asp-action="Index">Home</a> / Account</p>
            <h1 class="auth-title">Forgot Password</h1>
        </div>

        <div class="auth-wrap">
            <aside class="auth-side">
                <h2>Reset Your Access</h2>
                <p>Enter your account email and we will send you password reset instructions to regain access securely.</p>
                <ul class="auth-side-list">
                    <li>Quick secure reset process</li>
                    <li>Works with your registered account email</li>
                    <li>Return to login after reset instructions</li>
                </ul>
            </aside>

            <div class="auth-panel">
                <div class="auth-panel-head">
                    <h3>Password Recovery</h3>
                    <p>Provide your email to request a reset link.</p>
                </div>

                <div class="auth-body">
                    <form method="post" asp-action="ForgotPassword">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                        <div class="auth-group">
                            <label class="auth-label" asp-for="Email">Email Address</label>
                            <input class="auth-input" asp-for="Email" type="email" placeholder="you@example.com" />
                            <span asp-validation-for="Email"></span>
                        </div>

                        <button type="submit" class="auth-submit">Send Reset Link</button>

                        <div class="auth-footer">
                            <p class="mb-0">Remember your password? <a asp-action="Login" class="auth-link">Back to Sign In</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
