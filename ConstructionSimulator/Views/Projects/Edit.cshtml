@model Project
@{
    ViewData["Title"] = "Edit Project";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Edit Project</h1>
            <p class="app-hero-subtitle">Adjust timeline, budget, and status while keeping simulation metrics in sync.</p>
        </div>

        <div class="app-form-panel">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="ProjectId" />
                <input type="hidden" asp-for="CreatedDate" />
                <input type="hidden" asp-for="ActualCost" />

                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="app-form-grid">
                    <div class="app-field app-field-full">
                        <label asp-for="Name">Project Name</label>
                        <input asp-for="Name" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" rows="3"></textarea>
                        <span asp-validation-for="Description" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="StartDate">Start Date</label>
                        <input asp-for="StartDate" type="date" />
                        <span asp-validation-for="StartDate" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="EndDate">End Date</label>
                        <input asp-for="EndDate" type="date" />
                        <span asp-validation-for="EndDate" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="Budget">Budget ($)</label>
                        <input asp-for="Budget" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Budget" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="Status">Status</label>
                        <select asp-for="Status">
                            <option value="Planning">Planning</option>
                            <option value="In Progress">In Progress</option>
                            <option value="On Hold">On Hold</option>
                            <option value="Completed">Completed</option>
                        </select>
                        <span asp-validation-for="Status" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="app-panel" style="margin-top: 1.25rem;">
                    <div class="app-panel-body">
                        <p style="margin: 0; color: var(--ciq-text-body);">
                            <strong>Current Costs:</strong> $@Model.ActualCost.ToString("N2")
                            (@Model.BudgetUtilization.ToString("F1")% of budget)
                        </p>
                    </div>
                </div>

                <div class="app-form-actions">
                    <a asp-action="Details" asp-route-id="@Model.ProjectId" class="app-btn-secondary">Cancel</a>
                    <button type="submit" class="app-btn">Save Changes (with Simulation)</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}