@model IEnumerable<Project>
@{
    ViewData["Title"] = "Projects";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="display-4"><i class="bi bi-folder-fill"></i> Projects</h1>
                <p class="lead mb-0">Manage all construction projects</p>
            </div>
            <a asp-action="Create" class="btn btn-light btn-lg">
                <i class="bi bi-plus-circle"></i> Create New Project
            </a>
        </div>
    </div>
</div>

<div class="container">
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var project in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-@(project.Status == "Completed" ? "success" : project.Status == "In Progress" ? "primary" : "secondary") text-white">
                            <h5 class="mb-0">@project.Name</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">@project.Description</p>

                            <div class="mb-3">
                                <small class="text-muted d-block">Timeline</small>
                                <strong>@project.StartDate.ToString("MMM dd, yyyy") - @project.EndDate.ToString("MMM dd, yyyy")</strong>
                                <div class="text-muted small">@project.TotalDays days</div>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block">Budget Status</small>
                                <div class="progress mb-1" style="height: 25px;">
                                    <div class="progress-bar bg-@(project.BudgetUtilization > 100 ? "danger" : project.BudgetUtilization > 90 ? "warning" : "success")"
                                         style="width: @Math.Min(project.BudgetUtilization, 100)%">
                                        @project.BudgetUtilization.ToString("F1")%
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <small>Spent: $@project.ActualCost.ToString("N0")</small>
                                    <small>Budget: $@project.Budget.ToString("N0")</small>
                                </div>
                            </div>

                            @if (project.IsOverBudget)
                            {
                                <div class="alert alert-danger py-2 mb-2">
                                    <i class="bi bi-exclamation-triangle"></i> Over Budget!
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-light">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Details" asp-route-id="@project.ProjectID" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@project.ProjectID" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-folder-x" style="font-size: 4rem; color: #ccc;"></i>
                <h3 class="mt-3">No Projects Yet</h3>
                <p class="text-muted">Create your first construction project to get started.</p>
                <a asp-action="Create" class="btn btn-primary btn-lg mt-3">
                    <i class="bi bi-plus-circle"></i> Create First Project
                </a>
            </div>
        </div>
    }
</div>