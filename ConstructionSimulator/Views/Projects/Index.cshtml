@model List<Project>
@{
    ViewData["Title"] = "Projects";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Projects</h1>
            <p class="app-hero-subtitle">Manage and monitor all construction projects from one place.</p>
        </div>

        <div class="app-toolbar">
            <h2>All Projects</h2>
            <a asp-action="Create" class="app-btn">New Project</a>
        </div>

        @if (Model.Any())
        {
            <div class="app-card-grid">
                @foreach (var project in Model)
                {
                    var progress = Math.Min(project.BudgetUtilization, 100);
                    <article class="app-card">
                        <div class="app-card-head">
                            <h3 class="app-card-title">@project.Name</h3>
                            <p class="app-card-text">@((string.IsNullOrWhiteSpace(project.Description) ? "No description" : project.Description))</p>
                            <span class="app-status @(project.Status == "Planning" ? "app-status-planning" : project.Status == "In Progress" ? "app-status-progress" : "app-status-complete")">
                                @project.Status
                            </span>
                        </div>

                        <div class="app-card-body">
                            <div class="app-list">
                                <div class="app-list-row">
                                    <span class="app-label">Budget</span>
                                    <span class="app-value">$@project.Budget.ToString("N0")</span>
                                </div>
                                <div class="app-list-row">
                                    <span class="app-label">Start</span>
                                    <span class="app-value">@project.StartDate.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="app-list-row">
                                    <span class="app-label">End</span>
                                    <span class="app-value">@project.EndDate.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>

                            <div class="app-help">Budget Utilization</div>
                            <div class="app-progress">
                                <div class="app-progress-bar @(project.BudgetUtilization > 90 ? "app-progress-danger" : string.Empty)" style="width:@progress%">
                                    @project.BudgetUtilization.ToString("F0")%
                                </div>
                            </div>

                            <div class="app-form-actions" style="margin-top:0.9rem; padding-top:0.85rem;">
                                <a asp-action="Details" asp-route-id="@project.ProjectId" class="app-btn">View</a>
                                <a asp-action="Edit" asp-route-id="@project.ProjectId" class="app-btn-ghost">Edit</a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="app-panel">
                <div class="app-panel-body app-empty">
                    <h4>No projects yet</h4>
                    <p>Create your first project to begin planning, tracking, and conflict analysis.</p>
                    <a asp-action="Create" class="app-btn">Create Project</a>
                </div>
            </div>
        }
    </div>
</section>
