@model ProjectDetailsViewModel
@{
    ViewData["Title"] = "Project Details";

    decimal expectedCost = ViewBag.ExpectedCost != null ? (decimal)ViewBag.ExpectedCost : 0m;
    decimal budgetDifference = ViewBag.BudgetDifference != null ? (decimal)ViewBag.BudgetDifference : 0m;
    bool isOverBudget = ViewBag.IsOverBudget != null ? (bool)ViewBag.IsOverBudget : false;
    var breakdown = ViewBag.CostBreakdown as Dictionary<string, decimal>;
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">@Model.Project?.Name</h1>
            <p class="app-hero-subtitle">@Model.Project?.Description</p>
        </div>

        <div class="app-stats-row">
            <div class="app-stat">
                <p class="app-stat-label">Budget</p>
                <p class="app-stat-value">$@Model.Project?.Budget.ToString("N0")</p>
            </div>
            <div class="app-stat">
                <p class="app-stat-label">Actual Cost</p>
                <p class="app-stat-value">$@Model.Project?.ActualCost.ToString("N0")</p>
            </div>
            <div class="app-stat">
                <p class="app-stat-label">Duration</p>
                <p class="app-stat-value">@Model.Project?.TotalDays days</p>
            </div>
            <div class="app-stat">
                <p class="app-stat-label">Task Progress</p>
                <p class="app-stat-value">@Model.CompletedTasksCount / @Model.Tasks.Count</p>
            </div>
        </div>

        <div class="app-main-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:0.95rem; margin-bottom:1rem;">
            <section class="app-panel">
                <div class="app-panel-head"><h3>Budget Overview</h3></div>
                <div class="app-panel-body">
                    <div class="app-list">
                        <div class="app-list-row"><span class="app-label">Project Budget</span><span class="app-value">$@Model.Project?.Budget.ToString("N2")</span></div>
                        <div class="app-list-row"><span class="app-label">Expected Cost</span><span class="app-value">$@expectedCost.ToString("N2")</span></div>
                        <div class="app-list-row"><span class="app-label">Remaining Budget</span><span class="app-value @(isOverBudget ? "dash-danger" : "")">$@budgetDifference.ToString("N2")</span></div>
                    </div>
                    @if (isOverBudget)
                    {
                        <div class="app-warning" style="margin-top:0.8rem; margin-bottom:0;">Expected project cost exceeds allocated budget.</div>
                    }
                </div>
            </section>

            <section class="app-panel">
                <div class="app-panel-head"><h3>Cost Breakdown</h3></div>
                <div class="app-panel-body">
                    @if (breakdown != null)
                    {
                        <div class="app-list">
                            <div class="app-list-row"><span class="app-label">Labor</span><span class="app-value">$@breakdown["Labor"].ToString("N2")</span></div>
                            <div class="app-list-row"><span class="app-label">Materials</span><span class="app-value">$@breakdown["Materials"].ToString("N2")</span></div>
                            <div class="app-list-row"><span class="app-label">Permits</span><span class="app-value">$@breakdown["Permits"].ToString("N2")</span></div>
                            <div class="app-list-row"><span class="app-label">Other</span><span class="app-value">$@breakdown["Other"].ToString("N2")</span></div>
                        </div>
                    }
                    else
                    {
                        <p class="dash-muted">No cost breakdown available yet.</p>
                    }
                </div>
            </section>
        </div>

        @if (Model.ProjectConflicts.Any())
        {
            <section class="app-panel" style="margin-bottom:1rem;">
                <div class="app-panel-head"><h3>Project Conflicts (@Model.ProjectConflicts.Count)</h3></div>
                <div class="app-panel-body">
                    <div class="app-list">
                        @foreach (var conflict in Model.ProjectConflicts)
                        {
                            <article class="dash-list-item dash-conflict-item">
                                <div>
                                    <span class="dash-tag @(conflict.Severity == "Critical" ? "dash-tag-danger" : "dash-tag-warning")">@conflict.Severity</span>
                                    <span class="dash-tag dash-tag-secondary">@conflict.Type</span>
                                    <span class="dash-conflict-message">@conflict.Message</span>
                                </div>
                                <small>@conflict.DetectedDate.ToString("MMM dd, yyyy")</small>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }

        <section class="app-panel" style="margin-bottom:1rem;">
            <div class="app-panel-head">
                <h3>Project Tasks</h3>
                <a asp-controller="Tasks" asp-action="Create" asp-route-projectId="@Model.Project?.ProjectId" class="app-btn">Add Task</a>
            </div>
            <div class="app-panel-body">
                @if (Model.Tasks.Any())
                {
                    <div class="app-table-wrap">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>Task</th>
                                    <th>Dates</th>
                                    <th>Cost</th>
                                    <th>Crew</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in Model.Tasks.OrderBy(t => t.StartDate))
                                {
                                    <tr>
                                        <td>
                                            <p class="dash-strong">@task.Name</p>
                                            @if (!string.IsNullOrWhiteSpace(task.Description))
                                            {
                                                <p class="dash-muted">@task.Description</p>
                                            }
                                        </td>
                                        <td>
                                            <p class="dash-muted">@task.StartDate.ToString("MMM dd, yyyy") - @task.EndDate.ToString("MMM dd, yyyy")</p>
                                        </td>
                                        <td><span class="app-value">$@task.Cost.ToString("N0")</span></td>
                                        <td>
                                            @if (task.CrewId.HasValue)
                                            {
                                                var crew = Model.AvailableCrews.FirstOrDefault(c => c.CrewId == task.CrewId.Value);
                                                if (crew != null)
                                                {
                                                    <p class="dash-strong">@crew.Name</p>
                                                    <p class="dash-muted">@crew.SkillType</p>
                                                }
                                                else
                                                {
                                                    <p class="dash-muted">Not assigned</p>
                                                }
                                            }
                                            else
                                            {
                                                <p class="dash-muted">Not assigned</p>
                                            }
                                        </td>
                                        <td>
                                            <span class="dash-tag @(task.Status == "Completed" ? "dash-tag-success" : task.Status == "In Progress" ? "dash-tag-primary" : task.Status == "Blocked" ? "dash-tag-danger" : "dash-tag-secondary")">@task.Status</span>
                                        </td>
                                        <td>
                                            <span class="dash-tag @(task.Priority == "Critical" ? "dash-tag-danger" : task.Priority == "High" ? "dash-tag-warning" : task.Priority == "Medium" ? "dash-tag-info" : "dash-tag-secondary")">@task.Priority</span>
                                        </td>
                                        <td>
                                            <div class="app-inline-actions">
                                                <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.ProjectTaskId" class="app-btn-ghost app-btn-sm">Edit</a>
                                                <a asp-controller="Tasks" asp-action="Delete" asp-route-id="@task.ProjectTaskId" class="app-btn-danger app-btn-sm">Delete</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="app-empty">
                        <h4>No tasks yet</h4>
                        <p>Add your first task to start execution planning.</p>
                        <a asp-controller="Tasks" asp-action="Create" asp-route-projectId="@Model.Project?.ProjectId" class="app-btn">Add Task</a>
                    </div>
                }
            </div>
        </section>

        <div class="app-form-actions">
            <a asp-action="Index" class="app-btn-secondary">Back to Projects</a>
            <a asp-action="Edit" asp-route-id="@Model.Project?.ProjectId" class="app-btn-ghost">Edit Project</a>
            <a asp-action="Delete" asp-route-id="@Model.Project?.ProjectId" class="app-btn-danger">Delete Project</a>
        </div>
    </div>
</section>
