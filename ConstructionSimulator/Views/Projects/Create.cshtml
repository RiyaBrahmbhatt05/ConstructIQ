@model Project
@{
    ViewData["Title"] = "Create Project";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Create New Project</h1>
            <p class="app-hero-subtitle">Define project scope, budget, and schedule using the standard ConstructorIQ workflow.</p>
        </div>

        <div class="app-form-panel">
            <form method="post" asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Basic Information</h3>
                    <div class="app-form-grid">
                        <div class="app-field app-field-full">
                            <label asp-for="Name">Project Name</label>
                            <input asp-for="Name" placeholder="e.g., Downtown Office Complex" />
                            <span asp-validation-for="Name" class="field-validation-error"></span>
                        </div>

                        <div class="app-field app-field-full">
                            <label asp-for="Description">Description</label>
                            <textarea asp-for="Description" rows="4" placeholder="Describe scope, milestones, and delivery expectations"></textarea>
                            <span asp-validation-for="Description" class="field-validation-error"></span>
                        </div>

                        <div class="app-field">
                            <label asp-for="Status">Status</label>
                            <select asp-for="Status">
                                <option value="">Select Status</option>
                                <option value="Planning">Planning</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Completed">Completed</option>
                            </select>
                            <span asp-validation-for="Status" class="field-validation-error"></span>
                        </div>

                        <div class="app-field">
                            <label asp-for="Budget">Budget ($)</label>
                            <input asp-for="Budget" type="number" step="0.01" min="0" placeholder="0.00" />
                            <span asp-validation-for="Budget" class="field-validation-error"></span>
                        </div>

                        <div class="app-field">
                            <label asp-for="StartDate">Start Date</label>
                            <input asp-for="StartDate" type="date" />
                            <span asp-validation-for="StartDate" class="field-validation-error"></span>
                        </div>

                        <div class="app-field">
                            <label asp-for="EndDate">End Date</label>
                            <input asp-for="EndDate" type="date" />
                            <span asp-validation-for="EndDate" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="app-form-actions">
                    <a asp-action="Index" class="app-btn-secondary">Cancel</a>
                    <button type="submit" class="app-btn">Create Project</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
