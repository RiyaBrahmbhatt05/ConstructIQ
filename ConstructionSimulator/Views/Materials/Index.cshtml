@model IEnumerable<ConstructionSimulator.Models.Material>
@{
    ViewData["Title"] = "Materials";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Materials</h1>
            <p class="app-hero-subtitle">Track inventory, unit pricing, and stock availability.</p>
        </div>

        <div class="app-panel">
            <div class="app-panel-head">
                <h3>Material Inventory</h3>
                <a asp-action="Create" class="app-btn">Add Material</a>
            </div>
            <div class="app-panel-body">
                @if (Model.Any())
                {
                    <div class="app-table-wrap">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Cost / Unit</th>
                                    <th>Unit Type</th>
                                    <th>Quantity</th>
                                    <th>In Stock</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var material in Model)
                                {
                                    <tr>
                                        <td>@material.Name</td>
                                        <td>$@material.CostPerUnit.ToString("N2")</td>
                                        <td>@material.UnitType</td>
                                        <td>@material.Quantity</td>
                                        <td>
                                            <span class="app-status @(material.InStock ? "app-status-complete" : "app-status-planning")">
                                                @(material.InStock ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="app-inline-actions">
                                                <a asp-action="Edit" asp-route-id="@material.MaterialId" class="app-btn-ghost app-btn-sm">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@material.MaterialId" class="app-btn-danger app-btn-sm">Delete</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="app-empty">
                        <h4>No materials found</h4>
                        <p>Add your first material to build accurate cost and resource plans.</p>
                        <a asp-action="Create" class="app-btn">Create Material</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
