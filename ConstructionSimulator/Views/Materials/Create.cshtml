@model ConstructionSimulator.Models.Material
@{
    ViewData["Title"] = "Create Material";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Create Material</h1>
            <p class="app-hero-subtitle">Define inventory details for accurate procurement and cost planning.</p>
        </div>

        <div class="app-form-panel">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="app-form-grid">
                    <div class="app-field">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="Description"></label>
                        <input asp-for="Description" />
                    </div>

                    <div class="app-field">
                        <label asp-for="Quantity"></label>
                        <input asp-for="Quantity" type="number" min="0" />
                        <span asp-validation-for="Quantity" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="UnitType"></label>
                        <input asp-for="UnitType" />
                        <span asp-validation-for="UnitType" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="CostPerUnit"></label>
                        <input asp-for="CostPerUnit" type="number" step="0.01" min="0" />
                        <span asp-validation-for="CostPerUnit" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="LeadTimeDays"></label>
                        <input asp-for="LeadTimeDays" type="number" min="0" />
                    </div>

                    <div class="app-field app-field-full" style="display:flex; align-items:flex-end;">
                        <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                            <input asp-for="InStock" type="checkbox" /> In Stock
                        </label>
                    </div>
                </div>

                <div class="app-form-actions">
                    <a asp-action="Index" class="app-btn-secondary">Cancel</a>
                    <button type="submit" class="app-btn">Save Material</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
