@model ConstructionSimulator.Models.Material

@{
    ViewData["Title"] = "Delete Material";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Delete Material</h1>
            <p class="app-hero-subtitle">Confirm material removal from your inventory catalog.</p>
        </div>

        <div class="app-panel">
            <div class="app-panel-head">
                <h3>Confirm Deletion</h3>
                <span class="app-status app-status-planning">Permanent Action</span>
            </div>
            <div class="app-panel-body">
                <div class="app-warning" style="margin-bottom: 1rem;">
                    This material will no longer be available for task planning and cost estimates.
                </div>

                <div class="app-list" style="margin-bottom: 1rem;">
                    <div class="app-list-row"><span class="app-label">Name</span><span class="app-value">@Model.Name</span></div>
                    <div class="app-list-row"><span class="app-label">Cost Per Unit</span><span class="app-value">$@Model.CostPerUnit.ToString("N2")</span></div>
                    <div class="app-list-row"><span class="app-label">Unit Type</span><span class="app-value">@Model.UnitType</span></div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.MaterialId" />
                    <div class="app-form-actions" style="margin-top: 0;">
                        <a asp-action="Index" class="app-btn-secondary">Cancel</a>
                        <button type="submit" class="app-btn-danger">Delete Material</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
