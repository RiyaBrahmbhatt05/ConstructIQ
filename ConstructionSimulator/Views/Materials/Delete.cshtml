@model ConstructionSimulator.Models.Material

@{
    ViewData["Title"] = "Delete Material";
}

<div class="container mt-4">
    <h2>Delete Material</h2>
    <h4>Are you sure you want to delete this material?</h4>

    <hr />

    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Cost Per Unit</dt>
        <dd class="col-sm-9">@Model.CostPerUnit.ToString("N2")</dd>

        <dt class="col-sm-3">Unit Type</dt>
        <dd class="col-sm-9">@Model.UnitType</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" name="id" value="@Model.MaterialId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>