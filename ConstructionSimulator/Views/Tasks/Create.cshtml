@model ConstructionSimulator.Models.ProjectTask
@{
    ViewData["Title"] = "Create Task";
    var project = ViewBag.Project as Project;
    var crews = ViewBag.Crews as List<Crew>;
    var permits = ViewBag.Permits as List<Permit>;
    var tasks = ViewBag.Tasks as List<ConstructionSimulator.Models.ProjectTask>;
    var materialsList = ViewBag.MaterialsList as List<Material>;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, rgb(249, 250, 251) 0%, rgb(243, 244, 246) 100%);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .page-header {
        background: linear-gradient(135deg, rgb(107, 70, 210) 0%, rgb(88, 47, 192) 50%, rgb(68, 21, 182) 100%);
        color: white;
        padding: 3rem 0;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(107, 70, 210, 0.3);
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .page-header .container {
            position: relative;
            z-index: 2;
        }

        .page-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            letter-spacing: -1px;
        }

        .page-header p {
            font-size: 1.1rem;
            opacity: 0.9;
            margin: 0;
        }

    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .form-container {
        background: white;
        border-radius: 1.25rem;
        padding: 3rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(229, 231, 235, 0.5);
        margin-bottom: 3rem;
    }

    .form-section {
        margin-bottom: 3rem;
    }

        .form-section:last-child {
            margin-bottom: 0;
        }

    .section-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: rgb(31, 41, 55);
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid rgb(229, 231, 235);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        font-weight: 700;
        color: rgb(31, 41, 55);
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        padding: 0.95rem;
        border: 2px solid rgb(229, 231, 235);
        border-radius: 0.75rem;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: white;
        color: rgb(31, 41, 55);
        font-family: inherit;
    }

        .form-control:focus {
            outline: none;
            border-color: rgb(107, 70, 210);
            box-shadow: 0 0 0 3px rgba(107, 70, 210, 0.1);
            background: linear-gradient(135deg, rgba(107, 70, 210, 0.02) 0%, rgba(124, 81, 229, 0.02) 100%);
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .form-helper {
        font-size: 0.85rem;
        color: rgb(107, 114, 128);
        margin-top: 0.5rem;
        font-style: italic;
    }

    .error-message {
        color: rgb(239, 68, 68);
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: linear-gradient(135deg, rgba(107, 70, 210, 0.05) 0%, rgba(124, 81, 229, 0.05) 100%);
        border-radius: 0.75rem;
        border: 1px solid rgba(107, 70, 210, 0.1);
    }

        .form-check input {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: rgb(107, 70, 210);
        }

        .form-check label {
            flex: 1;
            font-weight: 600;
            color: rgb(31, 41, 55);
            cursor: pointer;
            margin: 0;
        }

    .alert-warning {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(217, 119, 6, 0.1) 100%);
        border-left: 4px solid rgb(245, 158, 11);
        padding: 1.5rem;
        border-radius: 0.75rem;
        color: rgb(92, 64, 51);
        margin-bottom: 2rem;
    }

        .alert-warning h5 {
            color: rgb(180, 83, 9);
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .alert-warning > div {
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

    .form-actions {
        display: flex;
        gap: 1.5rem;
        justify-content: flex-end;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 2px solid rgb(229, 231, 235);
    }

    .btn {
        padding: 0.95rem 2.5rem;
        border: none;
        border-radius: 0.75rem;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, rgb(107, 70, 210) 0%, rgb(124, 81, 229) 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(107, 70, 210, 0.3);
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(107, 70, 210, 0.4);
        }

    .btn-secondary {
        background: rgb(229, 231, 235);
        color: rgb(31, 41, 55);
    }

        .btn-secondary:hover {
            background: rgb(209, 213, 219);
        }

    @@media (max-width: 768px) {
        .page-header h1 {
            font-size: 1.75rem;
        }

        .form-container {
            padding: 1.5rem;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-plus-circle"></i> Create New Task</h1>
        <p>Add a new task to @project?.Name</p>
    </div>
</div>

<div class="container">
    <div class="form-container">
        @if (ViewBag.Conflicts != null && (ViewBag.Conflicts as List<ConflictAlert>).Any())
        {
            <div class="alert-warning">
                <h5><i class="bi bi-exclamation-triangle"></i> Conflicts Detected</h5>
                @foreach (var conflict in ViewBag.Conflicts as List<ConflictAlert>)
                {
                    <div>
                        <strong>[@conflict.Type - @conflict.Severity]</strong> @conflict.Message
                    </div>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            <input type="hidden" name="ProjectId" value="@ViewBag.ProjectId" />

            <!-- Basic Information -->
            <div class="form-section">
                <h2 class="section-title"><i class="bi bi-pencil-square"></i> Basic Information</h2>
                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="Name" class="form-label">Task Name *</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter task name" required />
                        <span asp-validation-for="Name" class="error-message"></span>
                    </div>
                </div>

                <div class="form-grid" style="margin-top: 2rem;">
                    <div class="form-group">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Brief description of the task"></textarea>
                        <span asp-validation-for="Description" class="error-message"></span>
                    </div>
                </div>
            </div>

            <!-- Schedule & Duration -->
            <div class="form-section">
                <h2 class="section-title"><i class="bi bi-calendar-event"></i> Schedule & Duration</h2>
                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="StartDate" class="form-label">Start Date *</label>
                        <input asp-for="StartDate" type="date" class="form-control" required />
                        <span asp-validation-for="StartDate" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EndDate" class="form-label">End Date *</label>
                        <input asp-for="EndDate" type="date" class="form-control" required />
                        <span asp-validation-for="EndDate" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Duration" class="form-label">Duration (days) *</label>
                        <input asp-for="Duration" type="number" class="form-control" min="1" required />
                        <span asp-validation-for="Duration" class="error-message"></span>
                    </div>
                </div>
            </div>

            <!-- Cost & Priority -->
            <div class="form-section">
                <h2 class="section-title"><i class="bi bi-lightning"></i> Cost & Priority</h2>
                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="Cost" class="form-label">Cost ($)</label>
                        <input asp-for="Cost" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Cost" class="error-message"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Priority" class="form-label">Priority *</label>
                        <select asp-for="Priority" class="form-control">
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Status" class="form-label">Status *</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Pending" selected>Pending</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Completed">Completed</option>
                            <option value="Blocked">Blocked</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Resources & Permits -->
            <div class="form-section">
                <h2 class="section-title"><i class="bi bi-gear"></i> Resources & Permits</h2>
                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="CrewId" class="form-label">Assign Crew</label>
                        <select asp-for="CrewId" class="form-control">
                            <option value="">-- No Crew Assigned --</option>
                            @if (crews != null)
                            {
                                @foreach (var crew in crews)
                                {
                                    <option value="@crew.CrewId">@crew.Name (@crew.SkillType) - $@crew.HourlyRate/hr</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Materials -->
                    <div class="form-section">
                        <h2 class="section-title"><i class="bi bi-box-seam"></i> Materials</h2>

                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Material 1</label>
                                <select name="materialIds" class="form-control">
                                    <option value="">-- Select Material --</option>
                                    @if (materialsList != null)
                                    {
                                        @foreach (var material in materialsList)
                                        {
                                            <option value="@material.MaterialId">
                                                @material.Name - $@material.CostPerUnit / @material.UnitType
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Units Required</label>
                                <input type="number" step="0.01" min="0" name="unitsRequired" class="form-control" placeholder="0" />
                            </div>
                        </div>

                        <div class="form-grid" style="margin-top: 2rem;">
                            <div class="form-group">
                                <label class="form-label">Material 2</label>
                                <select name="materialIds" class="form-control">
                                    <option value="">-- Select Material --</option>
                                    @if (materialsList != null)
                                    {
                                        @foreach (var material in materialsList)
                                        {
                                            <option value="@material.MaterialId">
                                                @material.Name - $@material.CostPerUnit / @material.UnitType
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Units Required</label>
                                <input type="number" step="0.01" min="0" name="unitsRequired" class="form-control" placeholder="0" />
                            </div>
                        </div>

                        <div class="form-grid" style="margin-top: 2rem;">
                            <div class="form-group">
                                <label class="form-label">Material 3</label>
                                <select name="materialIds" class="form-control">
                                    <option value="">-- Select Material --</option>
                                    @if (materialsList != null)
                                    {
                                        @foreach (var material in materialsList)
                                        {
                                            <option value="@material.MaterialId">
                                                @material.Name - $@material.CostPerUnit / @material.UnitType
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Units Required</label>
                                <input type="number" step="0.01" min="0" name="unitsRequired" class="form-control" placeholder="0" />
                            </div>
                        </div>

                        <div class="form-helper" style="margin-top: 1rem;">
                            Select up to 3 materials for this task. Cost will be calculated automatically based on material units and crew assignment.
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Dependencies" class="form-label">Dependencies</label>
                        <input asp-for="Dependencies" class="form-control" placeholder="e.g., 1,2,3" />
                        <div class="form-helper">Task IDs this task depends on (comma-separated)</div>
                    </div>
                </div>

                <div style="margin-top: 2rem;">
                    <div class="form-check">
                        <input asp-for="RequiresPermit" class="form-check-input" type="checkbox" id="requiresPermit" />
                        <label for="requiresPermit" class="form-check-label">
                            This task requires a permit
                        </label>
                    </div>
                </div>

                <div class="form-grid" style="margin-top: 2rem;">
                    <div class="form-group">
                        <label asp-for="PermitId" class="form-label">Select Permit</label>
                        <select asp-for="PermitId" class="form-control">
                            <option value="">-- No Permit --</option>
                            @if (permits != null)
                            {
                                @foreach (var permit in permits)
                                {
                                    <option value="@permit.PermitId">@permit.Type - @permit.Status ($@permit.Fee)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
                <a asp-controller="Projects" asp-action="Details" asp-route-id="@ViewBag.ProjectId" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Create Task (with Simulation)
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
