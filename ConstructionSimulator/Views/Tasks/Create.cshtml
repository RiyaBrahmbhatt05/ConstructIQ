@model ConstructionSimulator.Models.ProjectTask
@{
    ViewData["Title"] = "Create Task";
    var project = ViewBag.Project as Project;
    var crews = ViewBag.Crews as List<Crew>;
    var permits = ViewBag.Permits as List<Permit>;
    var materialsList = ViewBag.MaterialsList as List<Material>;
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Create New Task</h1>
            <p class="app-hero-subtitle">Add a task for @project?.Name with schedule, resources, and permit planning.</p>
        </div>

        <div class="app-form-panel">
            @if (ViewBag.Conflicts != null && (ViewBag.Conflicts as List<ConflictAlert>).Any())
            {
                <div class="app-warning">
                    <h3>Conflicts Detected</h3>
                    @foreach (var conflict in ViewBag.Conflicts as List<ConflictAlert>)
                    {
                        <div><strong>[@conflict.Type - @conflict.Severity]</strong> @conflict.Message</div>
                    }
                </div>
            }

            <form asp-action="Create" method="post">
                <input type="hidden" name="ProjectId" value="@ViewBag.ProjectId" />
                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Basic Information</h3>
                    <div class="app-form-grid">
                        <div class="app-field app-field-full">
                            <label asp-for="Name">Task Name *</label>
                            <input asp-for="Name" placeholder="Enter task name" required />
                            <span asp-validation-for="Name" class="field-validation-error"></span>
                        </div>
                        <div class="app-field app-field-full">
                            <label asp-for="Description">Description</label>
                            <textarea asp-for="Description" rows="3" placeholder="Brief description of the task"></textarea>
                            <span asp-validation-for="Description" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Schedule & Duration</h3>
                    <div class="app-form-grid">
                        <div class="app-field">
                            <label asp-for="StartDate">Start Date *</label>
                            <input asp-for="StartDate" type="date" required />
                            <span asp-validation-for="StartDate" class="field-validation-error"></span>
                        </div>
                        <div class="app-field">
                            <label asp-for="EndDate">End Date *</label>
                            <input asp-for="EndDate" type="date" required />
                            <span asp-validation-for="EndDate" class="field-validation-error"></span>
                        </div>
                        <div class="app-field">
                            <label asp-for="Duration">Duration (days) *</label>
                            <input asp-for="Duration" type="number" min="1" required />
                            <span asp-validation-for="Duration" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Cost & Priority</h3>
                    <div class="app-form-grid">
                        <div class="app-field">
                            <label asp-for="Cost">Cost ($)</label>
                            <input asp-for="Cost" type="number" step="0.01" min="0" placeholder="0.00" />
                            <span asp-validation-for="Cost" class="field-validation-error"></span>
                        </div>
                        <div class="app-field">
                            <label asp-for="Priority">Priority *</label>
                            <select asp-for="Priority">
                                <option value="Low">Low</option>
                                <option value="Medium" selected>Medium</option>
                                <option value="High">High</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>
                        <div class="app-field">
                            <label asp-for="Status">Status *</label>
                            <select asp-for="Status">
                                <option value="Pending" selected>Pending</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Completed">Completed</option>
                                <option value="Blocked">Blocked</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Resources & Permits</h3>
                    <div class="app-form-grid">
                        <div class="app-field">
                            <label asp-for="CrewId">Assign Crew</label>
                            <select asp-for="CrewId">
                                <option value="">-- No Crew Assigned --</option>
                                @if (crews != null)
                                {
                                    @foreach (var crew in crews)
                                    {
                                        <option value="@crew.CrewId">@crew.Name (@crew.SkillType) - $@crew.HourlyRate/hr</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="app-field">
                            <label asp-for="Dependencies">Dependencies</label>
                            <input asp-for="Dependencies" placeholder="e.g., 1,2,3" />
                            <div class="app-help">Task IDs this task depends on (comma-separated)</div>
                        </div>

                        <div class="app-field">
                            <label asp-for="PermitId">Select Permit</label>
                            <select asp-for="PermitId">
                                <option value="">-- No Permit --</option>
                                @if (permits != null)
                                {
                                    @foreach (var permit in permits)
                                    {
                                        <option value="@permit.PermitId">@permit.Type - @permit.Status ($@permit.Fee)</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="app-field" style="display:flex; align-items:flex-end;">
                            <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                                <input asp-for="RequiresPermit" type="checkbox" /> This task requires a permit
                            </label>
                        </div>
                    </div>
                </div>

                <div class="app-form-section">
                    <h3 class="app-form-title">Materials (up to 3)</h3>
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="app-form-grid" style="margin-bottom:0.7rem;">
                            <div class="app-field">
                                <label>Material @(i + 1)</label>
                                <select name="materialIds">
                                    <option value="">-- Select Material --</option>
                                    @if (materialsList != null)
                                    {
                                        @foreach (var material in materialsList)
                                        {
                                            <option value="@material.MaterialId">@material.Name - $@material.CostPerUnit / @material.UnitType</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="app-field">
                                <label>Units Required</label>
                                <input type="number" step="0.01" min="0" name="unitsRequired" placeholder="0" />
                            </div>
                        </div>
                    }
                    <p class="app-help">Cost is calculated automatically from selected materials and assigned crew.</p>
                </div>

                <div class="app-form-actions">
                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@ViewBag.ProjectId" class="app-btn-secondary">Cancel</a>
                    <button type="submit" class="app-btn">Create Task (with Simulation)</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
