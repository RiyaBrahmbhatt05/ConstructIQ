@model List<ProjectTask>
@{
    ViewData["Title"] = "Tasks";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, rgb(249, 250, 251) 0%, rgb(243, 244, 246) 100%);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }

    .page-header {
        background: linear-gradient(135deg, rgb(107, 70, 210) 0%, rgb(88, 47, 192) 50%, rgb(68, 21, 182) 100%);
        color: white;
        padding: 3rem 0;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(107, 70, 210, 0.3);
    }

    .page-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .page-header .container {
        position: relative;
        z-index: 2;
    }

    .page-header h1 {
        font-size: 2.75rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        letter-spacing: -1px;
    }

    .page-header p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin: 0;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .content-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: rgb(31, 41, 55);
    }

    .btn-primary {
        background: linear-gradient(135deg, rgb(107, 70, 210) 0%, rgb(124, 81, 229) 100%);
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(107, 70, 210, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(107, 70, 210, 0.4);
        color: white;
        text-decoration: none;
    }

    .tasks-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .task-card {
        background: white;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(229, 231, 235, 0.5);
        display: flex;
        flex-direction: column;
    }

    .task-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, rgb(107, 70, 210) 0%, rgb(124, 81, 229) 100%);
    }

    .task-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
        border-color: rgba(107, 70, 210, 0.2);
    }

    .task-header {
        padding: 1.5rem;
        background: linear-gradient(135deg, rgb(249, 250, 251) 0%, rgb(243, 244, 246) 100%);
        border-bottom: 1px solid rgba(229, 231, 235, 0.5);
        position: relative;
    }

    .task-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: rgb(31, 41, 55);
        margin-bottom: 0.75rem;
    }

    .task-body {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .task-info {
        margin-bottom: 1.5rem;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .info-item:last-child {
        margin-bottom: 0;
    }

    .info-label {
        font-weight: 600;
        color: rgb(107, 114, 128);
    }

    .info-value {
        color: rgb(31, 41, 55);
        font-weight: 700;
    }

    .priority-badge {
        display: inline-block;
        padding: 0.4rem 0.875rem;
        border-radius: 0.5rem;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .priority-critical {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%);
        color: rgb(185, 28, 28);
    }

    .priority-high {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.2) 0%, rgba(217, 119, 6, 0.2) 100%);
        color: rgb(180, 83, 9);
    }

    .priority-medium {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
        color: rgb(37, 99, 235);
    }

    .priority-low {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(5, 204, 159, 0.2) 100%);
        color: rgb(5, 150, 105);
    }

    .task-status {
        display: inline-block;
        padding: 0.4rem 0.875rem;
        border-radius: 0.5rem;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-pending {
        background: rgb(243, 244, 246);
        color: rgb(55, 65, 81);
    }

    .status-in-progress {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(91, 200, 255, 0.2) 100%);
        color: rgb(37, 99, 235);
    }

    .status-completed {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(5, 204, 159, 0.2) 100%);
        color: rgb(5, 150, 105);
    }

    .status-blocked {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.2) 100%);
        color: rgb(185, 28, 28);
    }

    .task-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: auto;
    }

    .btn-view {
        flex: 1;
        padding: 0.6rem;
        background: linear-gradient(135deg, rgb(107, 70, 210) 0%, rgb(124, 81, 229) 100%);
        color: white;
        border: none;
        border-radius: 0.5rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

    .btn-view:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(107, 70, 210, 0.3);
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 1rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(229, 231, 235, 0.5);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.3;
    }

    .empty-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: rgb(31, 41, 55);
        margin-bottom: 0.5rem;
    }

    .empty-text {
        color: rgb(107, 114, 128);
        font-size: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 768px) {
        .page-header h1 {
            font-size: 1.75rem;
        }

        .content-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .btn-primary {
            width: 100%;
            justify-content: center;
        }

        .tasks-grid {
            grid-template-columns: 1fr;
        }

        .task-actions {
            flex-direction: column;
        }

        .btn-view {
            width: 100%;
        }
    }
</style>

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-list-check"></i> All Tasks</h1>
        <p>Manage and track all your project tasks</p>
    </div>
</div>

<div class="container">
    <!-- Header -->
    <div class="content-header">
        <h2 class="content-title">Tasks Overview</h2>
        <a asp-controller="Projects" asp-action="Index" class="btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Projects
        </a>
    </div>

    <!-- Tasks Grid -->
    @if (Model.Any())
    {
        <div class="tasks-grid">
            @foreach (var task in Model)
            {
                <div class="task-card">
                    <div class="task-header">
                        <h3 class="task-name">@task.Name</h3>
                    </div>

                    <div class="task-body">
                        <div class="task-info">
                            <div class="info-item">
                                <span class="info-label">Priority</span>
                                <span class="priority-badge priority-@(task.Priority.ToLower())">
                                    @task.Priority
                                </span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Status</span>
                                <span class="task-status status-@(task.Status == "Pending" ? "pending" : task.Status == "In Progress" ? "in-progress" : task.Status == "Completed" ? "completed" : "blocked")">
                                    @task.Status
                                </span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Start Date</span>
                                <span class="info-value">@task.StartDate.ToString("MMM dd")</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">End Date</span>
                                <span class="info-value">@task.EndDate.ToString("MMM dd")</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Cost</span>
                                <span class="info-value">$@task.Cost.ToString("N0")</span>
                            </div>
                        </div>

                        <div class="task-actions">
                            <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.ProjectTaskId" class="btn-view">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">✓</div>
            <h2 class="empty-title">No Tasks Found</h2>
            <p class="empty-text">No tasks have been created yet. Create a project and add tasks to get started.</p>
            <a asp-controller="Projects" asp-action="Index" class="btn-primary">
                <i class="bi bi-arrow-left"></i> Back to Projects
            </a>
        </div>
    }
</div>
