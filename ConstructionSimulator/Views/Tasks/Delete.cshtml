@model ConstructionSimulator.Models.ProjectTask

@{
    ViewData["Title"] = "Delete Task";
}

<h2>Delete Task</h2>

<h4>Are you sure you want to delete this task?</h4>

<hr />

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Start Date</dt>
    <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>

    <dt class="col-sm-2">End Date</dt>
    <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Cost</dt>
    <dd class="col-sm-10">@Model.Cost</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="ProjectTaskId" value="@Model.ProjectTaskId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-secondary">Cancel</a>
</form>