@model ConstructionSimulator.Models.ProjectTask

@{
    ViewData["Title"] = "Delete Task";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Delete Task</h1>
            <p class="app-hero-subtitle">Review this task before permanently removing it from the project.</p>
        </div>

        <div class="app-panel">
            <div class="app-panel-head">
                <h3>Confirm Deletion</h3>
                <span class="app-status app-status-planning">Permanent Action</span>
            </div>
            <div class="app-panel-body">
                <div class="app-warning" style="margin-bottom: 1rem;">
                    Deleting this task will remove its planning record from the project timeline.
                </div>

                <div class="app-list" style="margin-bottom: 1rem;">
                    <div class="app-list-row"><span class="app-label">Name</span><span class="app-value">@Model.Name</span></div>
                    <div class="app-list-row"><span class="app-label">Description</span><span class="app-value">@Model.Description</span></div>
                    <div class="app-list-row"><span class="app-label">Start Date</span><span class="app-value">@Model.StartDate.ToShortDateString()</span></div>
                    <div class="app-list-row"><span class="app-label">End Date</span><span class="app-value">@Model.EndDate.ToShortDateString()</span></div>
                    <div class="app-list-row"><span class="app-label">Cost</span><span class="app-value">$@Model.Cost.ToString("N2")</span></div>
                    <div class="app-list-row"><span class="app-label">Status</span><span class="app-value">@Model.Status</span></div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="ProjectTaskId" value="@Model.ProjectTaskId" />
                    <div class="app-form-actions" style="margin-top: 0;">
                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="app-btn-secondary">Cancel</a>
                        <button type="submit" class="app-btn-danger">Delete Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
