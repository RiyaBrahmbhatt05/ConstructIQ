@model ConstructionSimulator.Models.Crew

@{
    ViewData["Title"] = "Delete Crew";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Delete Crew</h1>
            <p class="app-hero-subtitle">Confirm crew removal from workforce planning.</p>
        </div>

        <div class="app-panel">
            <div class="app-panel-head">
                <h3>Confirm Deletion</h3>
                <span class="app-status app-status-planning">Permanent Action</span>
            </div>
            <div class="app-panel-body">
                <div class="app-warning" style="margin-bottom: 1rem;">
                    Deleting this crew will remove it from future assignment options.
                </div>

                <div class="app-list" style="margin-bottom: 1rem;">
                    <div class="app-list-row"><span class="app-label">Name</span><span class="app-value">@Model.Name</span></div>
                    <div class="app-list-row"><span class="app-label">Skill Type</span><span class="app-value">@Model.SkillType</span></div>
                    <div class="app-list-row"><span class="app-label">Hourly Rate</span><span class="app-value">$@Model.HourlyRate.ToString("N2")</span></div>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.CrewId" />
                    <div class="app-form-actions" style="margin-top: 0;">
                        <a asp-action="Index" class="app-btn-secondary">Cancel</a>
                        <button type="submit" class="app-btn-danger">Delete Crew</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
