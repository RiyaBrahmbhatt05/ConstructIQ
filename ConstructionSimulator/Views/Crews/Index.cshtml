@model IEnumerable<ConstructionSimulator.Models.Crew>

@{
    ViewData["Title"] = "Crews";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Crews</h2>
        <a asp-action="Create" class="btn btn-primary">Add Crew</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Skill Type</th>
                <th>Team Size</th>
                <th>Hourly Rate</th>
                <th>Required Licenses</th>
                <th>Experience</th>
                <th>Available</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var crew in Model)
            {
                <tr>
                    <td>@crew.Name</td>
                    <td>@crew.SkillType</td>
                    <td>@crew.TeamSize</td>
                    <td>@crew.HourlyRate.ToString("N2")</td>
                    <td>@crew.RequiredLicenses</td>
                    <td>@crew.YearsOfExperience years</td>
                    <td>@(crew.IsAvailable ? "Yes" : "No")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@crew.CrewId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@crew.CrewId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>