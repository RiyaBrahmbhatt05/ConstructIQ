@model IEnumerable<ConstructionSimulator.Models.Crew>
@{
    ViewData["Title"] = "Crews";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Crews</h1>
            <p class="app-hero-subtitle">Manage team capabilities, availability, and labor rates.</p>
        </div>

        <div class="app-panel">
            <div class="app-panel-head">
                <h3>Crew Directory</h3>
                <a asp-action="Create" class="app-btn">Add Crew</a>
            </div>
            <div class="app-panel-body">
                @if (Model.Any())
                {
                    <div class="app-table-wrap">
                        <table class="app-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Skill Type</th>
                                    <th>Team Size</th>
                                    <th>Hourly Rate</th>
                                    <th>Experience</th>
                                    <th>Available</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var crew in Model)
                                {
                                    <tr>
                                        <td>@crew.Name</td>
                                        <td>@crew.SkillType</td>
                                        <td>@crew.TeamSize</td>
                                        <td>$@crew.HourlyRate.ToString("N2")</td>
                                        <td>@crew.YearsOfExperience years</td>
                                        <td>
                                            <span class="app-status @(crew.IsAvailable ? "app-status-complete" : "app-status-planning")">
                                                @(crew.IsAvailable ? "Yes" : "No")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="app-inline-actions">
                                                <a asp-action="Edit" asp-route-id="@crew.CrewId" class="app-btn-ghost app-btn-sm">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@crew.CrewId" class="app-btn-danger app-btn-sm">Delete</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="app-empty">
                        <h4>No crews found</h4>
                        <p>Create your first crew to assign workforce to project tasks.</p>
                        <a asp-action="Create" class="app-btn">Create Crew</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
