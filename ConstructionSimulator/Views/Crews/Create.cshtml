@model ConstructionSimulator.Models.Crew

@{
    ViewData["Title"] = "Create Crew";
}

<div class="container mt-4">
    <h2>Create Crew</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SkillType" class="form-label"></label>
            <input asp-for="SkillType" class="form-control" />
            <span asp-validation-for="SkillType" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TeamSize" class="form-label"></label>
            <input asp-for="TeamSize" class="form-control" />
            <span asp-validation-for="TeamSize" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="HourlyRate" class="form-label"></label>
            <input asp-for="HourlyRate" class="form-control" />
            <span asp-validation-for="HourlyRate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RequiredLicenses" class="form-label"></label>
            <input asp-for="RequiredLicenses" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="MemberNames" class="form-label"></label>
            <textarea asp-for="MemberNames" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="ContactDetails" class="form-label"></label>
            <textarea asp-for="ContactDetails" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="YearsOfExperience" class="form-label"></label>
            <input asp-for="YearsOfExperience" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control"></textarea>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsAvailable" class="form-check-input" />
            <label asp-for="IsAvailable" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}