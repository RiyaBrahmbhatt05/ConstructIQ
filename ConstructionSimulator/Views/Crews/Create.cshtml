@model ConstructionSimulator.Models.Crew
@{
    ViewData["Title"] = "Create Crew";
}

<section class="app-shell">
    <div class="app-container">
        <div class="app-hero">
            <h1 class="app-hero-title">Create Crew</h1>
            <p class="app-hero-subtitle">Capture team details to improve scheduling and labor cost planning.</p>
        </div>

        <div class="app-form-panel">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="app-form-grid">
                    <div class="app-field">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="SkillType"></label>
                        <input asp-for="SkillType" />
                        <span asp-validation-for="SkillType" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="TeamSize"></label>
                        <input asp-for="TeamSize" type="number" min="1" />
                        <span asp-validation-for="TeamSize" class="field-validation-error"></span>
                    </div>

                    <div class="app-field">
                        <label asp-for="HourlyRate"></label>
                        <input asp-for="HourlyRate" type="number" step="0.01" min="0" />
                        <span asp-validation-for="HourlyRate" class="field-validation-error"></span>
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="RequiredLicenses"></label>
                        <input asp-for="RequiredLicenses" />
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="MemberNames"></label>
                        <textarea asp-for="MemberNames" rows="3"></textarea>
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="ContactDetails"></label>
                        <textarea asp-for="ContactDetails" rows="3"></textarea>
                    </div>

                    <div class="app-field">
                        <label asp-for="YearsOfExperience"></label>
                        <input asp-for="YearsOfExperience" type="number" min="0" />
                    </div>

                    <div class="app-field app-field-full">
                        <label asp-for="Notes"></label>
                        <textarea asp-for="Notes" rows="3"></textarea>
                    </div>

                    <div class="app-field app-field-full" style="display:flex; align-items:flex-end;">
                        <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                            <input asp-for="IsAvailable" type="checkbox" /> Available for assignment
                        </label>
                    </div>
                </div>

                <div class="app-form-actions">
                    <a asp-action="Index" class="app-btn-secondary">Cancel</a>
                    <button type="submit" class="app-btn">Save Crew</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
