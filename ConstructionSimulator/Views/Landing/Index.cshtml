@{
    ViewData["Title"] = "ConstructorIQ | Build With Precision";
}

<style>
    .landing-shell {
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        width: 100vw;
        color: var(--landing-text);
        font-family: "Trebuchet MS", "Segoe UI", sans-serif;
        background: var(--landing-shell-bg);
    }

    .landing-shell * {
        box-sizing: border-box;
    }

    .landing-shell .section-wrap {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0;
    }

    .landing-shell .eyebrow {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--landing-eyebrow);
        margin-bottom: 1rem;
    }

    .landing-shell .headline {
        font-size: clamp(2rem, 4vw, 4.2rem);
        line-height: 1.08;
        letter-spacing: -0.02em;
        font-weight: 800;
        margin-bottom: 1.25rem;
    }

    .landing-shell .body-text {
        color: var(--landing-soft-text);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .landing-shell .btn-main,
    .landing-shell .btn-ghost {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.9rem 1.4rem;
        border-radius: 0.45rem;
        text-decoration: none;
        font-weight: 700;
        transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    }

    .landing-shell .btn-main {
        background: linear-gradient(90deg, var(--ciq-orange-1) 0%, var(--ciq-orange-2) 100%);
        color: #ffffff;
        box-shadow: 0 12px 28px rgba(193, 96, 36, 0.3);
    }

    .landing-shell .btn-main:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(193, 96, 36, 0.38);
        color: #ffffff;
    }

    .landing-shell .btn-ghost {
        border: 2px solid var(--landing-ghost-border);
        color: var(--ciq-navy-1);
        background-color: var(--landing-ghost-bg);
    }

    .landing-shell .btn-ghost:hover {
        transform: translateY(-2px);
        border-color: var(--ciq-orange-2);
        color: var(--ciq-orange-2);
    }

    .hero-block {
        position: relative;
        overflow: hidden;
        min-height: 680px;
        background:
            var(--landing-hero-overlay),
            url("https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=1800&q=80") center/cover no-repeat;
        display: flex;
        align-items: center;
    }

    .hero-block::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--landing-hero-glow);
        pointer-events: none;
    }

    .hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
        gap: 2rem;
        padding: 5.5rem 0;
    }

    .hero-copy {
        max-width: 700px;
        color: var(--landing-hero-text);
        animation: heroFade 0.9s ease;
    }

    .hero-copy .eyebrow {
        color: var(--landing-eyebrow);
    }

    .hero-copy .body-text {
        color: var(--landing-hero-soft);
        max-width: 620px;
    }

    .hero-actions {
        margin-top: 2rem;
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
    }

    .hero-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(120px, 1fr));
        gap: 1rem;
        margin-top: 2.2rem;
    }

    .hero-stat {
        border: 1px solid var(--landing-hero-stat-border);
        border-radius: 0.7rem;
        background: var(--landing-hero-stat-bg);
        padding: 0.9rem 1rem;
        backdrop-filter: blur(5px);
    }

    .hero-stat strong {
        display: block;
        font-size: 1.35rem;
        color: #ffffff;
    }

    .hero-stat span {
        font-size: 0.84rem;
        color: var(--landing-hero-stat-label);
        letter-spacing: 0.02em;
    }

    .hero-card {
        justify-self: end;
        width: min(430px, 100%);
        border-radius: 0.9rem;
        overflow: hidden;
        background: var(--landing-card-bg);
        box-shadow: 0 20px 45px rgba(6, 16, 24, 0.35);
        animation: heroFloat 2.4s ease-in-out infinite;
    }

    .hero-card .card-top {
        padding: 1.2rem 1.2rem 0.4rem;
        background: var(--landing-card-head-bg);
        border-bottom: 1px solid var(--landing-card-head-border);
    }

    .hero-card .card-top h3 {
        font-size: 1rem;
        margin: 0;
        font-weight: 800;
        color: var(--landing-card-title);
    }

    .hero-card .card-main {
        padding: 1.2rem;
    }

    .hero-card .site-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 0;
        border-bottom: 1px dashed var(--landing-card-row-border);
    }

    .hero-card .site-row:last-child {
        border-bottom: none;
    }

    .hero-card .site-row b {
        color: var(--landing-card-row-text);
    }

    .hero-card .pill {
        border-radius: 999px;
        padding: 0.2rem 0.6rem;
        font-size: 0.76rem;
        font-weight: 700;
        color: #ffffff;
    }

    .hero-card .pill.ontrack {
        background: #1f8e55;
    }

    .hero-card .pill.review {
        background: #d88b2c;
    }

    .hero-card .pill.delay {
        background: #be3a2f;
    }

    .about-block,
    .services-block,
    .projects-block,
    .process-block,
    .cta-block {
        padding: 5.2rem 0;
    }

    .about-block {
        background: var(--landing-about-bg);
    }

    .about-grid {
        display: grid;
        grid-template-columns: 0.95fr 1.05fr;
        gap: 2.2rem;
        align-items: center;
    }

    .about-media {
        position: relative;
        min-height: 420px;
    }

    .about-media img {
        width: 100%;
        height: 100%;
        min-height: 420px;
        object-fit: cover;
        border-radius: 0.9rem;
        box-shadow: 0 20px 38px rgba(9, 22, 33, 0.2);
    }

    .about-badge {
        position: absolute;
        left: 1.2rem;
        bottom: 1.2rem;
        background: var(--landing-section-surface);
        border-left: 5px solid var(--ciq-orange-1);
        padding: 0.9rem 1rem;
        border-radius: 0.45rem;
        box-shadow: 0 12px 22px rgba(12, 26, 37, 0.2);
    }

    .about-badge strong {
        display: block;
        font-size: 1.5rem;
        color: var(--landing-title-strong);
    }

    .about-points {
        margin-top: 1.5rem;
        display: grid;
        gap: 0.8rem;
    }

    .about-points div {
        background: var(--landing-section-surface);
        border: 1px solid var(--landing-border-soft);
        border-radius: 0.6rem;
        padding: 0.8rem 1rem;
        color: var(--landing-text);
        font-weight: 600;
    }

    .services-block {
        background: var(--landing-section-bg);
    }

    .services-grid {
        margin-top: 2.3rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.2rem;
    }

    .service-card {
        background: var(--landing-section-surface);
        border: 1px solid var(--landing-border-soft);
        border-radius: 0.75rem;
        padding: 1.3rem;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .service-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 30px rgba(7, 22, 34, 0.11);
    }

    .service-num {
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.11em;
        color: var(--ciq-orange-1);
        margin-bottom: 0.6rem;
    }

    .service-card h3 {
        font-size: 1.15rem;
        margin-bottom: 0.55rem;
        color: var(--landing-title-strong);
        font-weight: 800;
    }

    .service-card p {
        color: var(--landing-soft-text);
        margin: 0;
        line-height: 1.6;
    }

    .projects-block {
        background:
            linear-gradient(120deg, rgba(18, 37, 53, 0.97) 0%, rgba(18, 37, 53, 0.9) 100%),
            url("https://images.unsplash.com/photo-1593693397690-362cb9666fc2?auto=format&fit=crop&w=1800&q=80") center/cover no-repeat;
        color: #f6f8fb;
    }

    .projects-block .eyebrow {
        color: #ffa66a;
    }

    .projects-block .body-text {
        color: #d2dce6;
    }

    .projects-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .project-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 0.7rem;
        padding: 1rem;
        min-height: 180px;
    }

    .project-card h4 {
        font-size: 1.05rem;
        margin-bottom: 0.45rem;
    }

    .project-card p {
        margin-bottom: 0;
        color: #d3deea;
        font-size: 0.95rem;
    }

    .process-block {
        background: var(--landing-process-bg);
    }

    .process-grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .step-card {
        background: var(--landing-section-surface);
        border: 1px solid var(--landing-border-soft);
        border-radius: 0.65rem;
        padding: 1rem;
        position: relative;
        overflow: hidden;
    }

    .step-card::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--ciq-orange-1) 0%, var(--ciq-orange-2) 100%);
    }

    .step-card span {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--ciq-orange-1);
        margin-bottom: 0.45rem;
    }

    .step-card h4 {
        margin-bottom: 0.45rem;
        font-size: 1.06rem;
        color: var(--landing-title-strong);
    }

    .step-card p {
        margin: 0;
        color: var(--landing-soft-text);
    }

    .cta-block {
        background: linear-gradient(95deg, var(--ciq-orange-1) 0%, var(--ciq-orange-2) 100%);
        color: #ffffff;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .cta-block::before {
        content: "";
        position: absolute;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: var(--landing-cta-overlay);
        top: -90px;
        right: -40px;
    }

    .cta-block .section-wrap {
        position: relative;
        z-index: 2;
    }

    .cta-block h2 {
        font-size: clamp(1.8rem, 3.2vw, 3rem);
        margin-bottom: 0.8rem;
    }

    .cta-block p {
        margin: 0 auto 1.6rem;
        max-width: 760px;
        color: rgba(255, 255, 255, 0.9);
    }

    .cta-actions {
        display: flex;
        justify-content: center;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .cta-block .btn-main {
        background: var(--ciq-navy-1);
        color: #ffffff;
        box-shadow: 0 12px 28px rgba(13, 24, 34, 0.32);
    }

    .cta-block .btn-ghost {
        border-color: rgba(255, 255, 255, 0.75);
        color: #ffffff;
        background: transparent;
    }

    @@keyframes heroFade {
        from {
            opacity: 0;
            transform: translateY(18px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes heroFloat {
        0% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-8px);
        }
        100% {
            transform: translateY(0);
        }
    }

    @@media (max-width: 1100px) {
        .hero-grid,
        .about-grid {
            grid-template-columns: 1fr;
        }

        .hero-card {
            justify-self: start;
            width: 100%;
        }

        .services-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .projects-grid,
        .process-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 720px) {
        .hero-block {
            min-height: 560px;
        }

        .hero-actions,
        .cta-actions {
            flex-direction: column;
        }

        .hero-stats {
            grid-template-columns: 1fr;
        }

        .services-grid,
        .projects-grid,
        .process-grid {
            grid-template-columns: 1fr;
        }

        .about-media img,
        .about-media {
            min-height: 300px;
        }
    }
</style>

<div class="landing-shell">
    <section class="hero-block">
        <div class="section-wrap">
            <div class="hero-grid">
                <div class="hero-copy">
                    <span class="eyebrow">Building The Future</span>
                    <h1 class="headline">Strong Foundations For Smarter Construction Decisions</h1>
                    <p class="body-text">
                        ConstructorIQ helps you plan schedules, monitor materials, and catch project conflicts before they become expensive delays.
                        One platform for crews, costs, and confidence.
                    </p>
                    <div class="hero-actions">
                        <a href="@Url.Action("Register", "Account")" class="btn-main">Start Free Trial</a>
                        <a href="@Url.Action("Login", "Account")" class="btn-ghost">Sign In To Dashboard</a>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <strong>850+</strong>
                            <span>Managed Projects</span>
                        </div>
                        <div class="hero-stat">
                            <strong>96%</strong>
                            <span>Schedule Accuracy</span>
                        </div>
                        <div class="hero-stat">
                            <strong>$75M+</strong>
                            <span>Budget Value Tracked</span>
                        </div>
                        <div class="hero-stat">
                            <strong>24/7</strong>
                            <span>Project Visibility</span>
                        </div>
                    </div>
                </div>

                <aside class="hero-card" aria-label="Project health summary">
                    <div class="card-top">
                        <h3>Live Site Overview</h3>
                    </div>
                    <div class="card-main">
                        <div class="site-row">
                            <b>North Ridge Mall</b>
                            <span class="pill ontrack">On Track</span>
                        </div>
                        <div class="site-row">
                            <b>Harbor Office Tower</b>
                            <span class="pill review">Review</span>
                        </div>
                        <div class="site-row">
                            <b>Riverfront Housing</b>
                            <span class="pill delay">Delay Risk</span>
                        </div>
                        <div class="site-row">
                            <b>Warehouse Retrofit</b>
                            <span class="pill ontrack">On Track</span>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <section class="about-block">
        <div class="section-wrap">
            <div class="about-grid">
                <div class="about-media">
                    <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1100&q=80" alt="Construction team at work" />
                    <div class="about-badge">
                        <strong>18 Years</strong>
                        Proven planning and project intelligence.
                    </div>
                </div>
                <div>
                    <span class="eyebrow">About ConstructorIQ</span>
                    <h2 class="headline" style="font-size: clamp(1.8rem, 3vw, 3rem); color: var(--landing-title-strong);">Built for Project Managers, Engineers, and Owners</h2>
                    <p class="body-text">
                        Inspired by modern construction firms, ConstructorIQ combines budget tracking, crew planning, and material control
                        in one clean workflow. You get fast visibility, fewer surprises, and better delivery outcomes.
                    </p>
                    <div class="about-points">
                        <div>Forecast budget impact before tasks start.</div>
                        <div>Coordinate crew and material availability in real time.</div>
                        <div>Detect schedule and resource conflicts early.</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="services-block">
        <div class="section-wrap">
            <span class="eyebrow">Core Services</span>
            <h2 class="headline" style="font-size: clamp(1.8rem, 3vw, 3rem); color: var(--landing-title-strong);">Professional Construction Intelligence Services</h2>
            <p class="body-text" style="max-width: 760px;">
                Your existing modules already support operations. This landing layout highlights the same strengths in a modern visual style.
            </p>

            <div class="services-grid">
                <article class="service-card">
                    <div class="service-num">SERVICE 01</div>
                    <h3>Project Simulation</h3>
                    <p>Model timelines and dependencies to predict completion risks before execution starts.</p>
                </article>
                <article class="service-card">
                    <div class="service-num">SERVICE 02</div>
                    <h3>Conflict Detection</h3>
                    <p>Automatically flag overlaps in crew assignments, material shortages, and schedule clashes.</p>
                </article>
                <article class="service-card">
                    <div class="service-num">SERVICE 03</div>
                    <h3>Budget Visibility</h3>
                    <p>Track costs live against plan with clear indicators for overruns and usage trends.</p>
                </article>
                <article class="service-card">
                    <div class="service-num">SERVICE 04</div>
                    <h3>Material Planning</h3>
                    <p>Link task requirements to inventory so teams know exactly what is needed and when.</p>
                </article>
                <article class="service-card">
                    <div class="service-num">SERVICE 05</div>
                    <h3>Crew Coordination</h3>
                    <p>Keep workforce utilization balanced while protecting productivity and site safety.</p>
                </article>
                <article class="service-card">
                    <div class="service-num">SERVICE 06</div>
                    <h3>Execution Insights</h3>
                    <p>Turn project data into practical decisions for delivery speed and margin protection.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="projects-block">
        <div class="section-wrap">
            <span class="eyebrow">Recent Project Types</span>
            <h2 class="headline" style="font-size: clamp(1.8rem, 3vw, 3rem);">Completed Construction Programs</h2>
            <p class="body-text" style="max-width: 780px;">
                Showcase-ready cards inspired by the reference template, adapted to ConstructorIQ data-driven use cases.
            </p>

            <div class="projects-grid">
                <article class="project-card">
                    <h4>Commercial Tower</h4>
                    <p>Advanced schedule phasing and procurement monitoring across multi-crew operations.</p>
                </article>
                <article class="project-card">
                    <h4>Hospital Expansion</h4>
                    <p>Critical path visibility and material sequencing for zero-disruption execution.</p>
                </article>
                <article class="project-card">
                    <h4>Industrial Retrofit</h4>
                    <p>Conflict detection reduced idle crew time and minimized rework costs.</p>
                </article>
                <article class="project-card">
                    <h4>Residential Community</h4>
                    <p>Budget and supply alignment kept multiple parallel workstreams on schedule.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="process-block">
        <div class="section-wrap">
            <span class="eyebrow">Our Process</span>
            <h2 class="headline" style="font-size: clamp(1.8rem, 3vw, 3rem); color: var(--landing-title-strong);">How Teams Work With ConstructorIQ</h2>

            <div class="process-grid">
                <article class="step-card">
                    <span>STEP 01</span>
                    <h4>Define Project Scope</h4>
                    <p>Capture phases, tasks, and dependencies with clear baseline assumptions.</p>
                </article>
                <article class="step-card">
                    <span>STEP 02</span>
                    <h4>Assign Crews and Materials</h4>
                    <p>Connect labor and inventory to each task for reliable execution readiness.</p>
                </article>
                <article class="step-card">
                    <span>STEP 03</span>
                    <h4>Run Simulation Checks</h4>
                    <p>Validate potential conflicts and schedule bottlenecks before field rollout.</p>
                </article>
                <article class="step-card">
                    <span>STEP 04</span>
                    <h4>Monitor and Optimize</h4>
                    <p>Use real-time insights to keep progress, quality, and costs under control.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="cta-block">
        <div class="section-wrap">
            <h2>Ready To Plan Smarter and Build Faster?</h2>
            <p>Keep your current workflows and authentication exactly as they are. Start with a modern landing experience and scale page-by-page.</p>
            <div class="cta-actions">
                <a href="@Url.Action("Register", "Account")" class="btn-main">Create Your Account</a>
                <a href="@Url.Action("Login", "Account")" class="btn-ghost">Login</a>
            </div>
        </div>
    </section>
</div>