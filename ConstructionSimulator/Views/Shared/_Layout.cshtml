<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Construction Simulator</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();

        string ActiveClass(string controller, string action)
        {
            return currentController == controller.ToLowerInvariant() && currentAction == action.ToLowerInvariant() ? "active" : string.Empty;
        }
    }

    <nav class="navbar navbar-expand-lg navbar-dark navbar-ciq">
        <div class="container-fluid px-4">
            <a class="navbar-brand navbar-brand-ciq" asp-area="" asp-controller="Landing" asp-action="Index">
                Construction Simulator
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link nav-link-ciq @ActiveClass("Landing", "Index")" asp-area="" asp-controller="Landing" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-ciq @ActiveClass("Contact", "Index")" asp-area="" asp-controller="Contact" asp-action="Index">Contact</a>
                    </li>
                    <li class="nav-item">
                        <button id="themeToggleBtn" class="ciq-theme-btn" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
                            <span id="themeToggleIcon" aria-hidden="true">🌙</span>
                            <span id="themeToggleText">Dark</span>
                        </button>
                    </li>
                    @if (Context.Session.GetString("UserEmail") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq @ActiveClass("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq @ActiveClass("Projects", "Index")" asp-area="" asp-controller="Projects" asp-action="Index">Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq @ActiveClass("Materials", "Index")" asp-controller="Materials" asp-action="Index">Materials</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq @ActiveClass("Crews", "Index")" asp-controller="Crews" asp-action="Index">Crews</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link nav-link-ciq dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @{
                                    var userName = Context.Session.GetString("UserName") ?? "User";
                                }
                                👤 @userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end ciq-dropdown-menu" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item ciq-dropdown-item" asp-area="" asp-controller="Home" asp-action="Index">My Projects</a></li>
                                <li><hr class="dropdown-divider" style="margin: 0;"></li>
                                <li><a class="dropdown-item ciq-dropdown-item" asp-area="" asp-controller="Account" asp-action="Logout">Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq ciq-btn-login @ActiveClass("Account", "Login")" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-ciq ciq-btn-register @ActiveClass("Account", "Register")" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="layout-main">
        @{
            var successMessage = TempData["SuccessMessage"] as string;
            var errorMessage = TempData["ErrorMessage"] as string;
            var infoMessage = TempData["InfoMessage"] as string;
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="container mt-4">
                <div class="alert alert-success alert-dismissible fade show ciq-alert-success" role="alert">
                    ✓ @successMessage
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="container mt-4">
                <div class="alert alert-danger alert-dismissible fade show ciq-alert-danger" role="alert">
                    ✕ @errorMessage
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(infoMessage))
        {
            <div class="container mt-4">
                <div class="alert alert-info alert-dismissible fade show ciq-alert-info" role="alert">
                    ℹ @infoMessage
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        <div class="container">
            @RenderBody()
        </div>
    </div>

    <footer class="footer-ciq">
        <div class="container">
            <p style="margin: 0;">&copy; 2024 Construction Simulator - All rights reserved. | <a href="#">Privacy Policy</a> | <a href="#">Terms of Service</a></p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
