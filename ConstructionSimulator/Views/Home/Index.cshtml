@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="dash-page">
    <div class="dash-hero">
        <div class="dash-hero-content">
            <h1 class="dash-title">Project Dashboard</h1>
            <p class="dash-subtitle">Real-time construction intelligence for teams, budgets, and delivery</p>
            <div class="dash-hero-chips">
                <span class="dash-chip">Live Monitoring</span>
                <span class="dash-chip">Conflict Detection</span>
                <span class="dash-chip">Cost Visibility</span>
            </div>
        </div>
    </div>

    <div class="dash-stats-grid">
        <article class="dash-stat-card">
            <p class="dash-stat-label">Total Projects</p>
            <p class="dash-stat-value">@Model.TotalProjects</p>
            <p class="dash-stat-meta">Portfolio volume</p>
        </article>
        <article class="dash-stat-card">
            <p class="dash-stat-label">Active Projects</p>
            <p class="dash-stat-value">@Model.ActiveProjects</p>
            <p class="dash-stat-meta">Currently in progress</p>
        </article>
        <article class="dash-stat-card">
            <p class="dash-stat-label">Total Budget</p>
            <p class="dash-stat-value">$@Model.TotalBudget.ToString("N0")</p>
            <p class="dash-stat-meta">Allocated funds</p>
        </article>
        <article class="dash-stat-card">
            <p class="dash-stat-label">Overdue Tasks</p>
            <p class="dash-stat-value">@Model.OverdueTasks</p>
            <p class="dash-stat-meta">Need immediate review</p>
        </article>
    </div>

    @if (Model.Conflicts.Any())
    {
        <section class="dash-panel dash-panel-warning">
            <div class="dash-panel-head">
                <h2>Active Conflicts (@Model.Conflicts.Count)</h2>
            </div>
            <div class="dash-panel-body">
                <div class="dash-list">
                    @foreach (var conflict in Model.Conflicts.Take(5))
                    {
                        <article class="dash-list-item dash-conflict-item">
                            <div>
                                <span class="dash-tag @(conflict.Severity == "Critical" ? "dash-tag-danger" : conflict.Severity == "High" ? "dash-tag-warning" : "dash-tag-info")">@conflict.Severity</span>
                                <span class="dash-tag dash-tag-secondary">@conflict.Type</span>
                                <span class="dash-conflict-message">@conflict.Message</span>
                            </div>
                            <small>@conflict.DetectedDate.ToString("MMM dd, yyyy")</small>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    <div class="dash-main-grid">
        <section class="dash-panel">
            <div class="dash-panel-head">
                <h2>Recent Projects</h2>
                <a asp-controller="Projects" asp-action="Create" class="dash-btn">New Project</a>
            </div>
            <div class="dash-panel-body">
                @if (Model.RecentProjects.Any())
                {
                    <div class="dash-table-wrap">
                        <table class="dash-table">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Status</th>
                                    <th>Budget</th>
                                    <th>Utilization</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in Model.RecentProjects)
                                {
                                    var usage = Math.Min(project.BudgetUtilization, 100);
                                    <tr>
                                        <td>
                                            <p class="dash-strong">@project.Name</p>
                                            <p class="dash-muted">@((string.IsNullOrWhiteSpace(project.Description) ? "No description" : project.Description))</p>
                                        </td>
                                        <td>
                                            <span class="dash-tag @(project.Status == "Completed" ? "dash-tag-success" : project.Status == "In Progress" ? "dash-tag-primary" : "dash-tag-secondary")">@project.Status</span>
                                        </td>
                                        <td>
                                            <p class="dash-strong">$@project.Budget.ToString("N0")</p>
                                            <p class="dash-muted @(project.IsOverBudget ? "dash-danger" : string.Empty)">@project.BudgetUtilization.ToString("F1")% used</p>
                                        </td>
                                        <td>
                                            <div class="dash-progress">
                                                <div class="dash-progress-bar @(project.BudgetUtilization > 90 ? "dash-progress-danger" : string.Empty)" style="width:@usage%">
                                                    @project.BudgetUtilization.ToString("F0")%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.ProjectId" class="dash-btn dash-btn-ghost">View</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="dash-empty">
                        <p class="dash-empty-title">No projects yet</p>
                        <p class="dash-empty-text">Create your first project to start tracking delivery and costs.</p>
                        <a asp-controller="Projects" asp-action="Create" class="dash-btn">Create Project</a>
                    </div>
                }
            </div>
        </section>

        <section class="dash-panel">
            <div class="dash-panel-head">
                <h2>Upcoming Tasks</h2>
            </div>
            <div class="dash-panel-body">
                @if (Model.UpcomingTasks.Any())
                {
                    <div class="dash-list">
                        @foreach (var task in Model.UpcomingTasks)
                        {
                            <article class="dash-list-item">
                                <div>
                                    <p class="dash-strong">@task.Name</p>
                                    <p class="dash-muted">Starts @task.StartDate.ToString("MMM dd, yyyy")</p>
                                </div>
                                <span class="dash-tag @(task.Priority == "Critical" ? "dash-tag-danger" : task.Priority == "High" ? "dash-tag-warning" : "dash-tag-info")">@task.Priority</span>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div class="dash-empty">
                        <p class="dash-empty-title">No upcoming tasks</p>
                        <p class="dash-empty-text">All upcoming work is currently clear.</p>
                    </div>
                }
            </div>
        </section>
    </div>
</section>
